From aac1c5cc43e7f3e72072f05d6e68a48f4385f9a5 Mon Sep 17 00:00:00 2001
From: Jacob Moroni <jmoroni@google.com>
Date: Tue, 14 Apr 2026 15:24:52 +0000
Subject: [PATCH] irdma: Add UD queue depth clamping support

Added the ability to clamp the queue depth for UD QPs.

This feature comes in two forms:

1. Simple: Enabled by setting IRDMA_UD_QD_OVERRIDE. This will
   force the returned value of attr->cap.max_send_wr to the
   value specified. This may be sufficient for applications
   that honor the returned value even if it is lower than
   the requested depth.

2. Transparent: Enabled by setting IRDMA_TRANSPARENT_UD_QD_OVERRIDE.
   This will maintain the perception of the user's requested
   queue depth, but will limit the number of outstanding
   requests in the provider. Once the limit of outstanding
   requests is reached, any additional WQEs posted will be
   added to an overflow queue. When completions are polled, the
   head of the overflow queue will be re-submitted to the actual
   SQ.
   NOTE: This has the potential to break applications that do
         not regularly poll the SQ CQ. For example, if an
         application posts a series of send WQEs and relies
         only on the response from a peer to generate RQ
         completions before polling the SQ CQ, it may hang
         because only the first N SQ WQEs will actually be
         submitted.

These options can be used individually or together.

Signed-off-by: Jacob Moroni <jmoroni@google.com>
---
 providers/irdma/uk.c     |   8 ++
 providers/irdma/umain.c  |  34 +++++++
 providers/irdma/umain.h  |  14 +++
 providers/irdma/user.h   |  31 ++++++-
 providers/irdma/uverbs.c | 190 ++++++++++++++++++++++++++++++++++++---
 5 files changed, 266 insertions(+), 11 deletions(-)

diff --git a/providers/irdma/uk.c b/providers/irdma/uk.c
index e8216addb..05d57a59a 100644
--- a/providers/irdma/uk.c
+++ b/providers/irdma/uk.c
@@ -275,6 +275,12 @@ __le64 *irdma_qp_get_next_send_wqe(struct irdma_qp_uk *qp, __u32 *wqe_idx,
 	qp->sq_wrtrk_array[*wqe_idx].wr_len = total_size;
 	qp->sq_wrtrk_array[*wqe_idx].quanta = wqe_quanta;
 	qp->sq_wrtrk_array[*wqe_idx].signaled = info->signaled;
+	/* UD queue depth override requires all sends to be signaled. This is to
+	 * track whether the user really intended for this send to be signaled
+	 * or not.
+	 */
+	qp->sq_wrtrk_array[*wqe_idx].signaled_override =
+		info->signaled_override;
 	if (qp->uk_attrs->feature_flags & IRDMA_FEATURE_ENFORCE_SQ_SIZE) {
 		atomic_fetch_add(&qp->sq_ring.post_cnt, 1);
 		if (info->signaled) {
@@ -1568,6 +1574,8 @@ int irdma_uk_cq_poll_cmpl(struct irdma_cq_uk *cq,
 		}
 		pring = &qp->rq_ring;
 	} else { /* q_type is IRDMA_CQE_QTYPE_SQ */
+		info->signaled_override =
+			qp->sq_wrtrk_array[wqe_idx].signaled_override;
 		if (qp->first_sq_wq) {
 			if (wqe_idx + 1 >= qp->conn_wqes)
 				qp->first_sq_wq = false;
diff --git a/providers/irdma/umain.c b/providers/irdma/umain.c
index 6d6beeb2c..7d7a3ba1e 100644
--- a/providers/irdma/umain.c
+++ b/providers/irdma/umain.c
@@ -24,6 +24,8 @@
 
 struct irdma_env_params env = {
