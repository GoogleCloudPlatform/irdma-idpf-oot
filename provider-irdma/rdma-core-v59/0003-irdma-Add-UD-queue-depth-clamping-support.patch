+
+
+	env_val = getenv("IRDMA_TRANSPARENT_UD_QD_OVERRIDE");
+	if (env_val) {
+		tmp = atoi(env_val);
+		if (tmp < 0)
+			fprintf(stderr, "Ignoring invalid "
+				"IRDMA_TRANSPARENT_UD_QD_OVERRIDE value of "
