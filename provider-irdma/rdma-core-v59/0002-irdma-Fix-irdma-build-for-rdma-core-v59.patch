From 8d9de9a877ec0d0b9303cef8f30c0e2f60ca9e36 Mon Sep 17 00:00:00 2001
From: Jacob Moroni <jmoroni@google.com>
Date: Mon, 23 Jun 2025 14:55:49 +0000
Subject: [PATCH 2/2] irdma: Fix irdma build for rdma-core v59

The irdma provider is currently copied directly over
from rdma-core v35 and does not compile. This commit
fixes the compilation errors.

No significant functional change.

Signed-off-by: Jacob Moroni <jmoroni@google.com>
---
 providers/irdma/umain.c  | 2 +-
 providers/irdma/uverbs.c | 4 ----
 2 files changed, 1 insertion(+), 5 deletions(-)

diff --git a/providers/irdma/umain.c b/providers/irdma/umain.c
index e412ca348..058d642d1 100644
--- a/providers/irdma/umain.c
+++ b/providers/irdma/umain.c
@@ -193,7 +193,7 @@ static struct verbs_context *irdma_ualloc_context(struct ibv_device *ibdev,
 retry:
 	cmd.userspace_ver = user_ver;
 	ret = ibv_cmd_get_context(&iwvctx->ibv_ctx, (struct ibv_get_context *)&cmd,
-				  sizeof(cmd), &resp.ibv_resp, sizeof(resp));
+				  sizeof(cmd), NULL, &resp.ibv_resp, sizeof(resp));
 	if (ret) {
 		if (--user_ver >= 4)
 			goto retry;
diff --git a/providers/irdma/uverbs.c b/providers/irdma/uverbs.c
index 29179871b..65b512a81 100644
--- a/providers/irdma/uverbs.c
+++ b/providers/irdma/uverbs.c
@@ -91,11 +91,7 @@ struct ibv_mr *irdma_ureg_mr_dmabuf(struct ibv_pd *pd, uint64_t offset,
 		return NULL;
 
 	err = ibv_cmd_reg_dmabuf_mr(pd, offset, length, iova, fd, access,
-#ifdef IBV_CMD_REG_DMABUF_MR_VER_2
 				    vmr, NULL);
-#else
-				    vmr);
-#endif
 	if (err) {
 		free(vmr);
 		errno = err;
-- 
