 providers/irdma/uk.c           |  14 +++
 providers/irdma/umain.c        | 199 ++++++++++++++++++++++++++++++++-
 providers/irdma/umain.h        |   3 +
 providers/irdma/user.h         |  16 ++-
 providers/irdma/uverbs.c       |  74 ++++++++++--
 6 files changed, 295 insertions(+), 13 deletions(-)

