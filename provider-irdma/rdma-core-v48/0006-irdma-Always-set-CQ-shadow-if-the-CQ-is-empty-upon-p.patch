From a6dbba41897beada7e2ce1595d5544ee7dcc9a02 Mon Sep 17 00:00:00 2001
From: Jacob Moroni <jmoroni@google.com>
Date: Tue, 2 Sep 2025 16:28:31 +0000
Subject: [PATCH 1/1] irdma: Always set CQ shadow if the CQ is empty upon poll

The CQ translation fix introduces an edge case that can
result in continuous CQ event notifications if the CQ
happens to be left in a state where the real tail value
is even but the shadow is still odd. Work around this by
setting the CQ shadow to the true value as long as the
CQ is empty.

Signed-off-by: Jacob Moroni <jmoroni@google.com>
---
 providers/irdma/uk.c | 25 +++++++++++++++++++++----
 1 file changed, 21 insertions(+), 4 deletions(-)

diff --git a/providers/irdma/uk.c b/providers/irdma/uk.c
index 71f4cd85f..f5d41179b 100644
--- a/providers/irdma/uk.c
+++ b/providers/irdma/uk.c
@@ -1334,6 +1334,23 @@ static int irdma_check_sq_cqe(struct irdma_qp_uk *qp, __u32 *wqe_idx)
 	return 0;
 }
 
+static bool irdma_cq_empty(struct irdma_cq_uk *cq)
+{
+	__le64 *cqe;
+	__u8 polarity;
+	__u64 qword3;
+
+	if (cq->avoid_mem_cflct)
+		cqe = IRDMA_GET_CURRENT_EXTENDED_CQ_ELEM(cq);
+	else
+		cqe = IRDMA_GET_CURRENT_CQ_ELEM(cq);
+
+	get_64bit_val(cqe, 24, &qword3);
+	polarity = (__u8)FIELD_GET(IRDMA_CQ_VALID, qword3);
+
+	return polarity != cq->polarity;
+}
+
 /**
  * irdma_uk_cq_poll_cmpl - get cq completion info
  * @cq: hw cq
@@ -1553,8 +1570,8 @@ int irdma_uk_cq_poll_cmpl(struct irdma_cq_uk *cq,
 			if (wqe_idx < qp->conn_wqes && qp->sq_ring.head == qp->sq_ring.tail) {
 				IRDMA_RING_MOVE_HEAD_NOCHECK(cq->cq_ring);
 				IRDMA_RING_MOVE_TAIL(cq->cq_ring);
-				/* Avoid translation issue by never setting shadow to even value. */
-				if (IRDMA_RING_CURRENT_HEAD(cq->cq_ring) & 1) {
+				/* Avoid translation issue by never setting shadow to even value unless the CQ is empty. */
+				if (IRDMA_RING_CURRENT_HEAD(cq->cq_ring) & 1 || irdma_cq_empty(cq)) {
 					set_64bit_val(cq->shadow_area, 0,
 						      IRDMA_RING_CURRENT_HEAD(cq->cq_ring));
 				}
@@ -1656,8 +1673,8 @@ exit:
 		IRDMA_RING_MOVE_TAIL(cq->cq_ring);
 		if (!cq->avoid_mem_cflct && ext_valid)
 			IRDMA_RING_MOVE_TAIL(cq->cq_ring);
-		/* Avoid translation issue by never setting shadow to even value. */
-		if (IRDMA_RING_CURRENT_HEAD(cq->cq_ring) & 1) {
+		/* Avoid translation issue by never setting shadow to even value unless the CQ is empty. */
+		if (IRDMA_RING_CURRENT_HEAD(cq->cq_ring) & 1 || irdma_cq_empty(cq)) {
 			set_64bit_val(cq->shadow_area, 0,
 			      IRDMA_RING_CURRENT_HEAD(cq->cq_ring));
 		}
