From 13767a1df0d8badef4ee6141950687af0d405b45 Mon Sep 17 00:00:00 2001
From: Jacob Moroni <jmoroni@google.com>
Date: Fri, 5 Sep 2025 20:52:26 +0000
Subject: [PATCH 1/1] irdma: Avoid CQ sizes of exactly 1 page

If the CQ size works out to be 1 page, add 2 to
force it to require 2 pages. Sizes less than 1 page
are still okay.

Signed-off-by: Jacob Moroni <jmoroni@google.com>
---
 providers/irdma/uverbs.c | 8 +++++---
 1 file changed, 5 insertions(+), 3 deletions(-)

diff --git a/providers/irdma/uverbs.c b/providers/irdma/uverbs.c
index ddc377711..b739190a0 100644
--- a/providers/irdma/uverbs.c
+++ b/providers/irdma/uverbs.c
@@ -652,14 +652,16 @@ err_lock:
  */
 static inline int get_cq_size(int ncqe, __u8 hw_rev, bool cqe_64byte_ena)
 {
+	uint8_t cqe_size = cqe_64byte_ena ? 64 : 32;
+
 	ncqe += 2;
 
-	/* Completions with immediate require 1 extra entry */
-	if (!cqe_64byte_ena && hw_rev > IRDMA_GEN_1)
-		ncqe *= 2;
 	if (ncqe & 1)
 		ncqe += 1; /* cq size must be an even number */
 
+	if (ncqe * cqe_size == IRDMA_HW_PAGE_SIZE)
+		ncqe += 2;
+
 	if (ncqe < IRDMA_U_MINCQ_SIZE)
 		ncqe = IRDMA_U_MINCQ_SIZE;
 
