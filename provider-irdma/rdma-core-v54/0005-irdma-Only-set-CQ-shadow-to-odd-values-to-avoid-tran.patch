From 1b697bbfc10df568fd607378e720aa568f3ddcd6 Mon Sep 17 00:00:00 2001
From: Jacob Moroni <jmoroni@google.com>
Date: Thu, 21 Aug 2025 23:42:48 +0000
Subject: [PATCH 1/1] irdma: Only set CQ shadow to odd values to avoid
 translation issue

Normally, the CQ shadow is written to the current consumer value
every time a CQE is polled. The HW reads this shadow to determine
whether the CQ is full or not.

By never setting the CQ shadow to an even value, we ensure that
it never lands on a page boundary regardless of the page size,
thus avoiding a potential VA translation issue that can occur
at the page boundary.

The CQ size is therefore padded by 1 to accommodate for the fact
that software is essentially deferring the release of CQE slots
back to hardware by up to 1 entry.

Signed-off-by: Jacob Moroni <jmoroni@google.com>
---
 providers/irdma/uk.c     | 12 +++++++++---
 providers/irdma/uverbs.c |  2 +-
 2 files changed, 10 insertions(+), 4 deletions(-)

diff --git a/providers/irdma/uk.c b/providers/irdma/uk.c
index e6075e16f..71f4cd85f 100644
--- a/providers/irdma/uk.c
+++ b/providers/irdma/uk.c
@@ -1553,8 +1553,11 @@ int irdma_uk_cq_poll_cmpl(struct irdma_cq_uk *cq,
 			if (wqe_idx < qp->conn_wqes && qp->sq_ring.head == qp->sq_ring.tail) {
 				IRDMA_RING_MOVE_HEAD_NOCHECK(cq->cq_ring);
 				IRDMA_RING_MOVE_TAIL(cq->cq_ring);
-				set_64bit_val(cq->shadow_area, 0,
-					      IRDMA_RING_CURRENT_HEAD(cq->cq_ring));
+				/* Avoid translation issue by never setting shadow to even value. */
+				if (IRDMA_RING_CURRENT_HEAD(cq->cq_ring) & 1) {
+					set_64bit_val(cq->shadow_area, 0,
+						      IRDMA_RING_CURRENT_HEAD(cq->cq_ring));
+				}
 				memset(info, 0, sizeof(*info));
 				return irdma_uk_cq_poll_cmpl(cq, info);
 			}
@@ -1653,8 +1656,11 @@ exit:
 		IRDMA_RING_MOVE_TAIL(cq->cq_ring);
 		if (!cq->avoid_mem_cflct && ext_valid)
 			IRDMA_RING_MOVE_TAIL(cq->cq_ring);
-		set_64bit_val(cq->shadow_area, 0,
+		/* Avoid translation issue by never setting shadow to even value. */
+		if (IRDMA_RING_CURRENT_HEAD(cq->cq_ring) & 1) {
+			set_64bit_val(cq->shadow_area, 0,
 			      IRDMA_RING_CURRENT_HEAD(cq->cq_ring));
+		}
 	} else {
 		qword3 &= ~IRDMA_CQ_WQEIDX;
 		qword3 |= FIELD_PREP(IRDMA_CQ_WQEIDX, pring->tail);
diff --git a/providers/irdma/uverbs.c b/providers/irdma/uverbs.c
index be23f7c40..dcebdd39c 100644
--- a/providers/irdma/uverbs.c
+++ b/providers/irdma/uverbs.c
@@ -652,7 +652,7 @@ err_lock:
  */
 static inline int get_cq_size(int ncqe, __u8 hw_rev, bool cqe_64byte_ena)
 {
-	ncqe++;
+	ncqe += 2;
 
 	/* Completions with immediate require 1 extra entry */
 	if (!cqe_64byte_ena && hw_rev > IRDMA_GEN_1)
